:root {
  --bg: #f3f6f1;
  --panel: rgba(255, 255, 255, 0.88);
  --panel-strong: rgba(255, 255, 255, 0.96);
  --panel-border: rgba(168, 185, 163, 0.42);
  --surface-soft: rgba(255, 255, 255, 0.78);
  --surface-strong: rgba(255, 255, 255, 0.92);
  --glass: rgba(243, 246, 241, 0.82);
  --input-bg: rgba(255, 255, 255, 0.84);
  --line: #d6dfd3;
  --line-strong: #a8b9a3;
  --text: #1a2a23;
  --muted: #4b6056;
  --brand: #0e7a64;
  --brand-strong: #005747;
  --accent: #ff7f32;
  --danger: #aa2a2a;
  --badge-off-bg: rgba(172, 95, 38, 0.16);
  --badge-off-text: #8a4613;
  --chart-primary: #0e7a64;
  --chart-secondary: #ff7f32;
  --chart-up: #0e7a64;
  --chart-down: #b04444;
  --chart-grid: rgba(168, 185, 163, 0.46);
  --chart-axis: rgba(75, 96, 86, 0.9);
  --chart-axis-strong: #30473e;
  --chart-empty: #4b6056;
  --chart-guide: rgba(0, 87, 71, 0.34);
  --chart-selection-fill: rgba(14, 122, 100, 0.12);
  --chart-selection-stroke: rgba(14, 122, 100, 0.34);
  --chart-candle-guide: rgba(82, 70, 36, 0.36);
  --chart-bg-top: rgba(14, 122, 100, 0.06);
  --chart-bg-bottom: rgba(14, 122, 100, 0.01);
  --chart-candle-bg-top: rgba(255, 127, 50, 0.05);
  --chart-candle-bg-bottom: rgba(255, 127, 50, 0.01);
  --tooltip-border: rgba(0, 87, 71, 0.15);
  --tooltip-bg: rgba(17, 31, 28, 0.92);
  --tooltip-text: #f7faf8;
  --tooltip-muted: rgba(247, 250, 248, 0.74);
  --backdrop-spot-a: rgba(255, 127, 50, 0.24);
  --backdrop-spot-b: rgba(14, 122, 100, 0.18);
  --backdrop-base-start: #f8fbf6;
  --backdrop-base-end: #edf3ee;
  --shadow: 0 14px 38px rgba(13, 61, 51, 0.12);
}

*,
*::before,
*::after {
  box-sizing: border-box;
}

html,
body {
  margin: 0;
  padding: 0;
  min-height: 100%;
}

body {
  font-family: "Space Grotesk", "Segoe UI", sans-serif;
  color: var(--text);
  background: var(--bg);
  transition: background-color 180ms ease, color 180ms ease;
}

body[data-theme="midnight"] {
  --bg: #0d1319;
  --panel: rgba(15, 23, 34, 0.88);
  --panel-strong: rgba(18, 28, 42, 0.94);
  --panel-border: rgba(90, 110, 133, 0.34);
  --surface-soft: rgba(22, 33, 48, 0.78);
  --surface-strong: rgba(21, 31, 46, 0.94);
  --glass: rgba(13, 19, 25, 0.84);
  --input-bg: rgba(11, 20, 31, 0.86);
  --line: #253242;
  --line-strong: #5a6d82;
  --text: #eef3fb;
  --muted: #aeb8c4;
  --brand: #7ad8c7;
  --brand-strong: #2a9b8a;
  --accent: #f5b24d;
  --danger: #ff948e;
  --badge-off-bg: rgba(245, 178, 77, 0.18);
  --badge-off-text: #ffd296;
  --chart-primary: #7ad8c7;
  --chart-secondary: #f5b24d;
  --chart-up: #7ad8c7;
  --chart-down: #ff948e;
  --chart-grid: rgba(90, 110, 133, 0.42);
  --chart-axis: rgba(174, 184, 196, 0.92);
  --chart-axis-strong: #f0f5fb;
  --chart-empty: #c0cad7;
  --chart-guide: rgba(122, 216, 199, 0.38);
  --chart-selection-fill: rgba(122, 216, 199, 0.12);
  --chart-selection-stroke: rgba(122, 216, 199, 0.4);
  --chart-candle-guide: rgba(245, 178, 77, 0.34);
  --chart-bg-top: rgba(122, 216, 199, 0.09);
  --chart-bg-bottom: rgba(122, 216, 199, 0.02);
  --chart-candle-bg-top: rgba(245, 178, 77, 0.08);
  --chart-candle-bg-bottom: rgba(245, 178, 77, 0.02);
  --tooltip-border: rgba(122, 216, 199, 0.22);
  --tooltip-bg: rgba(7, 11, 18, 0.96);
  --tooltip-text: #f6fbff;
  --tooltip-muted: rgba(246, 251, 255, 0.76);
  --backdrop-spot-a: rgba(245, 178, 77, 0.18);
  --backdrop-spot-b: rgba(122, 216, 199, 0.16);
  --backdrop-base-start: #111a23;
  --backdrop-base-end: #0a1016;
  --shadow: 0 18px 42px rgba(0, 0, 0, 0.36);
}

body[data-theme="gold"] {
  --bg: #f7f0dd;
  --panel: rgba(255, 250, 239, 0.9);
  --panel-strong: rgba(255, 252, 245, 0.97);
  --panel-border: rgba(160, 124, 43, 0.28);
  --surface-soft: rgba(255, 250, 239, 0.8);
  --surface-strong: rgba(255, 252, 245, 0.94);
  --glass: rgba(247, 240, 221, 0.84);
  --input-bg: rgba(255, 251, 242, 0.94);
  --line: #d8c49b;
  --line-strong: #b08a3f;
  --text: #3d2d14;
  --muted: #6b5b3f;
  --brand: #c69212;
  --brand-strong: #8f5f03;
  --accent: #2146c7;
  --danger: #a2352d;
  --badge-off-bg: rgba(33, 70, 199, 0.12);
  --badge-off-text: #2146c7;
  --chart-primary: #c69212;
  --chart-secondary: #2146c7;
  --chart-up: #b7810d;
  --chart-down: #a2352d;
  --chart-grid: rgba(176, 138, 63, 0.36);
  --chart-axis: rgba(107, 91, 63, 0.92);
  --chart-axis-strong: #4e3c1a;
  --chart-empty: #6b5b3f;
  --chart-guide: rgba(143, 95, 3, 0.28);
  --chart-selection-fill: rgba(198, 146, 18, 0.12);
  --chart-selection-stroke: rgba(143, 95, 3, 0.32);
  --chart-candle-guide: rgba(33, 70, 199, 0.22);
  --chart-bg-top: rgba(198, 146, 18, 0.08);
  --chart-bg-bottom: rgba(198, 146, 18, 0.015);
  --chart-candle-bg-top: rgba(33, 70, 199, 0.06);
  --chart-candle-bg-bottom: rgba(33, 70, 199, 0.01);
  --tooltip-border: rgba(143, 95, 3, 0.16);
  --tooltip-bg: rgba(58, 41, 11, 0.94);
  --tooltip-text: #fff7e8;
  --tooltip-muted: rgba(255, 247, 232, 0.74);
  --backdrop-spot-a: rgba(198, 146, 18, 0.2);
  --backdrop-spot-b: rgba(33, 70, 199, 0.12);
  --backdrop-base-start: #fff8ea;
  --backdrop-base-end: #f2e4bc;
  --shadow: 0 16px 38px rgba(122, 89, 23, 0.17);
}

body[data-theme="ice"] {
  --bg: #eef5fb;
  --panel: rgba(255, 255, 255, 0.86);
  --panel-strong: rgba(255, 255, 255, 0.95);
  --panel-border: rgba(125, 153, 181, 0.28);
  --surface-soft: rgba(255, 255, 255, 0.74);
  --surface-strong: rgba(255, 255, 255, 0.92);
  --glass: rgba(238, 245, 251, 0.84);
  --input-bg: rgba(255, 255, 255, 0.9);
  --line: #cbdbe8;
  --line-strong: #7d99b5;
  --text: #152739;
  --muted: #4f667c;
  --brand: #2a7ab6;
  --brand-strong: #114d79;
  --accent: #ff9152;
  --danger: #b84454;
  --badge-off-bg: rgba(255, 145, 82, 0.14);
  --badge-off-text: #b65f1e;
  --chart-primary: #2a7ab6;
  --chart-secondary: #ff9152;
  --chart-up: #2a7ab6;
  --chart-down: #b84454;
  --chart-grid: rgba(125, 153, 181, 0.4);
  --chart-axis: rgba(79, 102, 124, 0.92);
  --chart-axis-strong: #19354d;
  --chart-empty: #4f667c;
  --chart-guide: rgba(42, 122, 182, 0.28);
  --chart-selection-fill: rgba(42, 122, 182, 0.12);
  --chart-selection-stroke: rgba(42, 122, 182, 0.32);
  --chart-candle-guide: rgba(255, 145, 82, 0.32);
  --chart-bg-top: rgba(42, 122, 182, 0.08);
  --chart-bg-bottom: rgba(42, 122, 182, 0.015);
  --chart-candle-bg-top: rgba(255, 145, 82, 0.05);
  --chart-candle-bg-bottom: rgba(255, 145, 82, 0.01);
  --tooltip-border: rgba(42, 122, 182, 0.16);
  --tooltip-bg: rgba(17, 44, 67, 0.92);
  --tooltip-text: #f2f8ff;
  --tooltip-muted: rgba(242, 248, 255, 0.74);
  --backdrop-spot-a: rgba(255, 145, 82, 0.18);
  --backdrop-spot-b: rgba(42, 122, 182, 0.16);
  --backdrop-base-start: #f9fcff;
  --backdrop-base-end: #e4eef7;
}

.backdrop {
  position: fixed;
  inset: 0;
  z-index: -1;
  background:
    radial-gradient(900px 600px at 82% -12%, var(--backdrop-spot-a), transparent 72%),
    radial-gradient(820px 520px at -4% 28%, var(--backdrop-spot-b), transparent 68%),
    linear-gradient(180deg, var(--backdrop-base-start) 0%, var(--backdrop-base-end) 100%);
}

.topbar {
  position: sticky;
  top: 0;
  z-index: 50;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1.2rem;
  padding: 0.9rem 1.35rem;
  border-bottom: 1px solid rgba(122, 216, 199, 0.12);
  background:
    radial-gradient(820px 220px at 82% -80%, rgba(122, 216, 199, 0.15), transparent 70%),
    linear-gradient(180deg, rgba(11, 17, 24, 0.94), rgba(10, 15, 20, 0.88));
  backdrop-filter: blur(18px);
  box-shadow: 0 18px 60px rgba(0, 0, 0, 0.18);
}

.brand {
  display: grid;
  gap: 0.2rem;
  min-width: 250px;
}

.brand h1 {
  margin: 0;
  color: #f5f9ff;
  font-size: clamp(1.55rem, 2.15vw, 2.25rem);
  line-height: 0.96;
  letter-spacing: -0.045em;
  white-space: nowrap;
}

.eyebrow {
  margin: 0;
  color: rgba(238, 247, 245, 0.62);
  font-size: 0.76rem;
  font-weight: 700;
  letter-spacing: 0.02em;
}

.topbar-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 0.58rem;
  flex: 1 1 auto;
  min-width: 0;
  width: auto;
}

.account-menu-wrap {
  position: relative;
  display: inline-flex;
}

.plan-control,
.technical-status {
  display: none !important;
}

.account-chip {
  display: inline-flex;
  align-items: center;
  gap: 0.65rem;
  min-height: 46px;
  border: 1px solid rgba(122, 216, 199, 0.16);
  border-radius: 999px;
  padding: 0.42rem 0.92rem 0.42rem 0.52rem;
  background: linear-gradient(180deg, rgba(23, 34, 48, 0.92), rgba(15, 23, 34, 0.88));
  color: #f3f8fb;
  cursor: pointer;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06), 0 12px 34px rgba(0, 0, 0, 0.18);
  transition: transform 0.16s ease, border-color 0.16s ease, background 0.16s ease, box-shadow 0.16s ease;
}

.account-chip:hover {
  transform: translateY(-1px);
  border-color: rgba(122, 216, 199, 0.36);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08), 0 16px 40px rgba(0, 0, 0, 0.24);
}

.account-chip strong,
.account-chip small {
  display: block;
  line-height: 1.05;
  text-align: left;
}

.account-chip strong {
  font-size: 0.86rem;
}

.account-chip small {
  margin-top: 0.18rem;
  color: rgba(238, 247, 245, 0.66);
  font-size: 0.68rem;
}

.account-chip-active {
  border-color: rgba(122, 216, 199, 0.38);
  background: linear-gradient(180deg, rgba(24, 48, 54, 0.95), rgba(15, 31, 38, 0.9));
}

.account-dot {
  width: 0.72rem;
  height: 0.72rem;
  border-radius: 999px;
  background: var(--accent);
  box-shadow: 0 0 0 0.32rem rgba(255, 127, 50, 0.14);
}

.account-chip-active .account-dot {
  background: var(--brand);
  box-shadow: 0 0 0 0.32rem rgba(14, 122, 100, 0.14);
}

.account-menu {
  position: absolute;
  top: calc(100% + 0.62rem);
  right: 0;
  z-index: 90;
  width: min(330px, calc(100vw - 2rem));
  padding: 0.48rem;
  border: 1px solid rgba(122, 216, 199, 0.18);
  border-radius: 24px;
  background:
    radial-gradient(320px 180px at 100% 0%, rgba(122, 216, 199, 0.13), transparent 72%),
    linear-gradient(180deg, rgba(18, 28, 39, 0.98), rgba(8, 13, 20, 0.98));
  box-shadow: 0 28px 80px rgba(0, 0, 0, 0.36);
  backdrop-filter: blur(18px);
  transform-origin: top right;
  animation: menu-pop 160ms ease;
}

.account-menu[hidden] {
  display: none;
}

@keyframes menu-pop {
  from {
    opacity: 0;
    transform: translateY(-6px) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.account-menu-item {
  width: 100%;
  display: grid;
  gap: 0.12rem;
  border: 0;
  border-radius: 18px;
  padding: 0.72rem 0.82rem;
  background: transparent;
  color: rgba(247, 251, 255, 0.94);
  text-align: left;
  cursor: pointer;
  transition: background 0.16s ease, transform 0.16s ease;
}

.account-menu-item::before {
  content: none !important;
}

.account-menu-item:hover {
  background: rgba(122, 216, 199, 0.1);
  transform: translateX(2px);
}

.account-menu-item span {
  font-weight: 900;
}

.account-menu-item small {
  color: rgba(238, 247, 245, 0.56);
  font-size: 0.72rem;
}

.account-menu-item.danger span {
  color: #ffb4ad;
}

.account-menu .file-btn {
  overflow: hidden;
  justify-content: flex-start;
}

.account-menu .file-btn::before {
  content: none;
}

.tabs {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.78rem 1.35rem;
  border-bottom: 1px solid rgba(122, 216, 199, 0.1);
  background:
    linear-gradient(180deg, rgba(19, 28, 36, 0.72), rgba(15, 22, 29, 0.62)),
    var(--glass);
  backdrop-filter: blur(14px);
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scroll-snap-type: x proximity;
}

.tab {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  gap: 0.52rem;
  border: 1px solid rgba(122, 216, 199, 0.12);
  background: rgba(18, 27, 38, 0.72);
  color: rgba(238, 247, 245, 0.78);
  border-radius: 999px;
  padding: 0.52rem 0.98rem;
  min-height: 44px;
  font-size: 0.9rem;
  font-weight: 800;
  cursor: pointer;
  white-space: nowrap;
  scroll-snap-align: start;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.035);
  transition: transform 0.18s ease, border-color 0.18s ease, background-color 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
}

.tab-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 1.15rem;
  font-size: 0.92em;
}

.tab:hover {
  transform: translateY(-1px);
  border-color: rgba(122, 216, 199, 0.3);
  color: #f7fffd;
  background: rgba(24, 36, 49, 0.86);
}

.tab.active {
  color: #ffffff;
  background:
    radial-gradient(circle at 18% 12%, rgba(255, 255, 255, 0.22), transparent 32%),
    linear-gradient(135deg, #83dccd 0%, #36a893 100%);
  border-color: transparent;
  box-shadow: 0 16px 42px rgba(54, 168, 147, 0.28);
}

.container {
  max-width: 1480px;
  margin: 0 auto;
  padding: 1.1rem 1.3rem 4.6rem;
}

.view {
  display: none;
  animation: rise-in 220ms ease;
}

.view.active {
  display: block;
}

@keyframes rise-in {
  from {
    opacity: 0;
    transform: translateY(6px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.grid-two {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1rem;
  margin-bottom: 1rem;
}

.panel {
  background: var(--panel);
  border: 1px solid var(--panel-border);
  border-radius: 20px;
  box-shadow: var(--shadow);
  padding: 1rem;
}

.panel h2 {
  margin: 0 0 0.8rem;
  font-size: 1.12rem;
}

.panel h3 {
  margin: 1rem 0 0.45rem;
  font-size: 0.95rem;
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  flex-wrap: wrap;
}

.dashboard-controls {
  display: flex;
  align-items: flex-end;
  gap: 0.65rem;
  flex-wrap: wrap;
}

.dashboard-controls .control.inline {
  min-width: 170px;
}

.dashboard-inflation-toggle {
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding-right: 0.2rem;
  min-width: 200px;
}

.dashboard-inflation-toggle input {
  width: auto;
}

.dashboard-inflation-rate input {
  min-width: 120px;
}

.actions-inline {
  display: flex;
  gap: 0.65rem;
  align-items: flex-end;
  flex-wrap: wrap;
}

.actions-inline .control.inline {
  flex: 1 1 160px;
  min-width: 0;
}

.chart-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  flex-wrap: wrap;
  margin-top: 0.5rem;
}

.chart-toolbar-actions {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  flex-wrap: wrap;
}

.chart-range-group {
  display: inline-flex;
  gap: 0.4rem;
  flex-wrap: wrap;
}

.chart-mode-group {
  display: inline-flex;
  gap: 0.4rem;
  flex-wrap: wrap;
}

.chart-range-btn {
  min-height: 36px;
  padding: 0.44rem 0.72rem;
  border-radius: 999px;
}

.chart-mode-btn {
  min-height: 36px;
  padding: 0.44rem 0.72rem;
  border-radius: 999px;
}

.chart-range-btn.active {
  background: linear-gradient(120deg, var(--brand-strong), var(--brand));
  border-color: transparent;
  color: #ffffff;
}

.chart-mode-btn.active {
  background: linear-gradient(120deg, var(--brand-strong), var(--brand));
  border-color: transparent;
  color: #ffffff;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.6rem;
}

.form-grid .full {
  grid-column: 1 / -1;
}

.control {
  display: flex;
  flex-direction: column;
  gap: 0.28rem;
}

.control > span {
  font-size: 0.78rem;
  color: var(--muted);
}

.topbar .control {
  min-width: 132px;
  gap: 0.38rem;
}

.topbar .control > span {
  color: rgba(238, 247, 245, 0.62);
  font-size: 0.76rem;
  font-weight: 800;
}

.control.inline {
  min-width: 160px;
}

.control.switch {
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding-right: 0.2rem;
}

input,
select,
textarea,
button {
  font: inherit;
}

input,
select,
textarea {
  width: 100%;
  border: 1px solid var(--line);
  border-radius: 11px;
  padding: 0.54rem 0.6rem;
  color: var(--text);
  background: var(--input-bg);
}

.topbar select {
  min-height: 46px;
  border-color: rgba(122, 216, 199, 0.14);
  border-radius: 16px;
  padding: 0.58rem 2.15rem 0.58rem 0.78rem;
  background:
    linear-gradient(180deg, rgba(18, 27, 38, 0.92), rgba(12, 19, 28, 0.9));
  color: #f7fbff;
  font-weight: 900;
  letter-spacing: -0.015em;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.055), 0 12px 32px rgba(0, 0, 0, 0.14);
}

.topbar .btn,
.topbar .file-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.48rem;
  min-height: 46px;
  padding-inline: 0.86rem;
  font-size: 0.86rem;
}

.topbar .btn::before,
.topbar .file-btn::before {
  display: inline-grid;
  place-items: center;
  width: 1.12rem;
  height: 1.12rem;
  border-radius: 999px;
  background: rgba(122, 216, 199, 0.11);
  color: rgba(247, 251, 255, 0.86);
  font-size: 0.72rem;
  line-height: 1;
}

#themeToggleBtn::before {
  content: "◐";
}

#exportBackupBtn::before {
  content: "↗";
}

.topbar .file-btn::before {
  content: "↙";
}

#cloudSyncLogoutBtn::before {
  content: "×";
}

#refreshQuotesBtn::before {
  content: "↻";
}

.toast-host {
  position: fixed;
  top: 1rem;
  right: 1rem;
  z-index: 220;
  display: grid;
  gap: 0.55rem;
  width: min(380px, calc(100vw - 2rem));
  pointer-events: none;
}

.toast {
  pointer-events: auto;
  display: grid;
  gap: 0.15rem;
  border: 1px solid rgba(122, 216, 199, 0.18);
  border-radius: 18px;
  padding: 0.78rem 0.9rem;
  background:
    radial-gradient(260px 160px at 100% 0%, rgba(122, 216, 199, 0.13), transparent 72%),
    linear-gradient(180deg, rgba(18, 28, 39, 0.97), rgba(8, 13, 20, 0.97));
  color: #f4fbff;
  box-shadow: 0 24px 70px rgba(0, 0, 0, 0.35);
  animation: toast-in 180ms ease;
}

.toast strong {
  font-size: 0.82rem;
}

.toast span {
  color: rgba(238, 247, 245, 0.72);
  font-size: 0.78rem;
  line-height: 1.35;
}

.toast-success {
  border-color: rgba(122, 216, 199, 0.36);
}

.toast-error {
  border-color: rgba(255, 148, 142, 0.36);
}

.toast-error strong {
  color: #ffb4ad;
}

@keyframes toast-in {
  from {
    opacity: 0;
    transform: translateY(-8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

textarea {
  resize: vertical;
}

input:focus,
select:focus,
textarea:focus {
  outline: none;
  border-color: var(--brand);
  box-shadow: 0 0 0 3px rgba(14, 122, 100, 0.15);
}

.btn {
  border: 1px solid transparent;
  border-radius: 999px;
  background:
    radial-gradient(circle at 18% 12%, rgba(255, 255, 255, 0.22), transparent 34%),
    linear-gradient(135deg, #83dccd 0%, #36a893 100%);
  color: #ffffff;
  font-weight: 900;
  letter-spacing: -0.015em;
  padding: 0.62rem 0.98rem;
  min-height: 44px;
  cursor: pointer;
  box-shadow: 0 14px 34px rgba(54, 168, 147, 0.24);
  transition: transform 0.18s ease, filter 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
}

.btn:hover {
  transform: translateY(-1px);
  filter: brightness(1.02);
  box-shadow: 0 18px 42px rgba(54, 168, 147, 0.3);
}

.btn:active {
  transform: translateY(0);
}

.btn.secondary {
  background: linear-gradient(180deg, rgba(18, 27, 38, 0.9), rgba(12, 19, 28, 0.86));
  border-color: rgba(122, 216, 199, 0.14);
  color: rgba(247, 251, 255, 0.92);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.055), 0 12px 32px rgba(0, 0, 0, 0.14);
}

.btn.secondary:hover {
  border-color: rgba(122, 216, 199, 0.34);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.075), 0 16px 40px rgba(0, 0, 0, 0.2);
}

.btn.secondary.is-active {
  background: linear-gradient(120deg, var(--brand-strong), var(--brand));
  border-color: transparent;
  color: #ffffff;
}

.btn.danger {
  background: linear-gradient(180deg, rgba(57, 25, 31, 0.9), rgba(32, 15, 20, 0.86));
  border-color: rgba(255, 148, 142, 0.24);
  color: #ffb4ad;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.055), 0 12px 32px rgba(0, 0, 0, 0.14);
}

.btn.link {
  min-height: auto;
  padding: 0.2rem 0.35rem;
  border: 0;
  background: transparent;
  color: var(--brand);
  box-shadow: none;
  text-decoration: underline;
  text-underline-offset: 0.2em;
}

.btn.link:hover {
  transform: none;
  filter: none;
  box-shadow: none;
  color: var(--brand-strong);
}

.file-btn {
  position: relative;
  overflow: hidden;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.file-btn input[type="file"] {
  position: absolute;
  inset: 0;
  opacity: 0;
  cursor: pointer;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  gap: 0.6rem;
  margin: 0.85rem 0;
}

.dashboard-premium-head {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 0.9rem;
  align-items: stretch;
  margin: 0.95rem 0 0.65rem;
}

.stat-card {
  border: 1px solid var(--line);
  background: var(--surface-soft);
  border-radius: 16px;
  padding: 0.75rem;
}

.stat-card-hero {
  position: relative;
  overflow: hidden;
  min-height: 184px;
  border-color: rgba(122, 216, 199, 0.2);
  border-radius: 26px;
  padding: 1.25rem;
  background:
    radial-gradient(520px 260px at 100% 0%, rgba(122, 216, 199, 0.2), transparent 70%),
    radial-gradient(420px 220px at 0% 100%, rgba(255, 127, 50, 0.13), transparent 72%),
    linear-gradient(135deg, rgba(18, 28, 39, 0.96), rgba(7, 12, 18, 0.92));
  color: #f6fffd;
  box-shadow: 0 28px 80px rgba(3, 10, 14, 0.26);
}

.stat-card p {
  margin: 0;
  font-size: 0.76rem;
  color: var(--muted);
}

.stat-card strong {
  display: block;
  margin-top: 0.18rem;
  font-size: 1.16rem;
}

.stat-card-hero > strong {
  margin-top: 0.42rem;
  font-size: clamp(2.15rem, 5vw, 4.2rem);
  line-height: 0.96;
  letter-spacing: -0.07em;
}

.stat-card-hero p {
  color: rgba(238, 247, 245, 0.72);
  font-weight: 800;
}

.hero-stat-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
  margin-top: 1rem;
}

.hero-stat-meta span {
  display: inline-flex;
  align-items: center;
  gap: 0.42rem;
  border: 1px solid rgba(122, 216, 199, 0.15);
  border-radius: 999px;
  padding: 0.34rem 0.58rem;
  color: rgba(238, 247, 245, 0.66);
  background: rgba(255, 255, 255, 0.045);
  font-size: 0.78rem;
}

.hero-stat-meta strong {
  display: inline;
  margin: 0;
  color: #ffffff;
  font-size: 0.8rem;
}

.dashboard-quick-actions {
  display: grid;
  align-content: stretch;
  gap: 0.55rem;
  min-width: 210px;
}

.dashboard-quick-actions .btn {
  justify-content: center;
  min-height: 54px;
}

.dashboard-mini-stats {
  grid-template-columns: repeat(4, minmax(150px, 1fr));
}

.stat-card-meta {
  display: block;
  margin-top: 0.32rem;
  font-size: 0.78rem;
  color: var(--muted);
}

.empty-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin: 0.8rem 0;
  border: 1px solid rgba(122, 216, 199, 0.18);
  border-radius: 22px;
  padding: 1.1rem;
  background:
    radial-gradient(420px 190px at 0% 0%, rgba(122, 216, 199, 0.16), transparent 70%),
    linear-gradient(135deg, rgba(18, 28, 39, 0.92), rgba(9, 15, 22, 0.88));
  color: #effffc;
}

.empty-hero[hidden] {
  display: none;
}

.empty-hero h3 {
  margin: 0.2rem 0 0.25rem;
  font-size: 1.15rem;
}

.empty-hero p {
  max-width: 760px;
  margin: 0;
  color: rgba(238, 247, 245, 0.7);
}

.onboarding-card {
  display: grid;
  grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.22fr);
  gap: 0.9rem;
  align-items: center;
  margin: 0.8rem 0;
  border: 1px solid var(--panel-border);
  border-radius: 22px;
  padding: 1rem;
  background:
    radial-gradient(420px 190px at 100% 0%, var(--chart-bg-top), transparent 70%),
    var(--surface-soft);
}

.onboarding-card[hidden] {
  display: none;
}

.onboarding-card h3 {
  margin: 0.25rem 0 0;
}

.onboarding-steps {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0.55rem;
}

.onboarding-step {
  border: 1px solid var(--panel-border);
  border-radius: 18px;
  padding: 0.72rem;
  background: var(--surface-strong);
  color: var(--text);
  text-align: left;
  cursor: pointer;
  transition: transform 0.16s ease, border-color 0.16s ease, box-shadow 0.16s ease;
}

.onboarding-step:hover {
  transform: translateY(-1px);
  border-color: var(--line-strong);
  box-shadow: var(--shadow);
}

.onboarding-step strong {
  display: inline-grid;
  place-items: center;
  width: 1.6rem;
  height: 1.6rem;
  margin-bottom: 0.42rem;
  border-radius: 999px;
  background: linear-gradient(135deg, #83dccd 0%, #36a893 100%);
  color: #ffffff;
}

.onboarding-step span {
  display: block;
  font-weight: 900;
}

.empty-kicker {
  display: inline-flex;
  border: 1px solid rgba(122, 216, 199, 0.2);
  border-radius: 999px;
  padding: 0.2rem 0.48rem;
  color: rgba(122, 216, 199, 0.95);
  font-size: 0.68rem;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.chart-wrap {
  position: relative;
  overflow: hidden;
  border: 1px solid var(--line);
  border-radius: 16px;
  background:
    radial-gradient(120% 120% at 100% 0%, var(--chart-bg-top), transparent 48%),
    linear-gradient(180deg, var(--panel-strong) 0%, var(--surface-soft) 100%);
  padding: 0.8rem;
  margin-top: 0.6rem;
}

#dashboardView .chart-wrap {
  border-radius: 24px;
  padding: 1rem;
}

canvas {
  display: block;
  width: 100%;
  height: auto;
}

.chart-tooltip {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 2;
  min-width: 132px;
  max-width: 220px;
  padding: 0.55rem 0.65rem;
  border: 1px solid var(--tooltip-border);
  border-radius: 14px;
  background: var(--tooltip-bg);
  color: var(--tooltip-text);
  box-shadow: 0 14px 34px rgba(8, 22, 18, 0.24);
  pointer-events: none;
  opacity: 0;
  transform: translate(0, 0);
  transition: opacity 120ms ease;
}

.chart-tooltip.visible {
  opacity: 1;
}

.chart-tooltip-label {
  display: block;
  margin-bottom: 0.14rem;
  font-size: 0.72rem;
  color: var(--tooltip-muted);
}

.chart-tooltip-value {
  display: block;
  font-size: 0.98rem;
  font-weight: 700;
  letter-spacing: 0.01em;
}

.chart-tooltip-meta {
  display: block;
  margin-top: 0.28rem;
  font-size: 0.72rem;
  line-height: 1.45;
  color: var(--tooltip-muted);
}

.hint.compact {
  margin: 0;
}

.table-wrap {
  overflow-x: auto;
}

.record-list {
  display: grid;
  gap: 0.72rem;
  margin-top: 0.7rem;
}

.record-card {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 0.8rem;
  align-items: start;
  border: 1px solid var(--panel-border);
  border-radius: 20px;
  padding: 0.9rem;
  background:
    radial-gradient(360px 160px at 100% 0%, var(--chart-bg-top), transparent 72%),
    var(--surface-soft);
  cursor: pointer;
  transition: transform 0.16s ease, border-color 0.16s ease, box-shadow 0.16s ease;
}

.record-card:hover {
  transform: translateY(-2px);
  border-color: var(--line-strong);
  box-shadow: var(--shadow);
}

.record-main {
  min-width: 0;
}

.record-kicker {
  display: block;
  margin-bottom: 0.22rem;
  color: var(--muted);
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.02em;
}

.record-title {
  margin: 0;
  font-size: 1rem;
  line-height: 1.15;
}

.record-subtitle {
  margin: 0.28rem 0 0;
  color: var(--muted);
  font-size: 0.82rem;
}

.record-value {
  text-align: right;
  white-space: nowrap;
}

.record-value strong {
  display: block;
  font-size: 1rem;
}

.record-value span {
  color: var(--muted);
  font-size: 0.76rem;
}

.record-actions {
  grid-column: 1 / -1;
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
}

.record-actions .btn {
  min-height: 34px;
  padding: 0.42rem 0.68rem;
  font-size: 0.78rem;
}

.record-tags {
  grid-column: 1 / -1;
  display: flex;
  flex-wrap: wrap;
  gap: 0.34rem;
}

.record-tag {
  border: 1px solid var(--line);
  border-radius: 999px;
  padding: 0.16rem 0.42rem;
  color: var(--muted);
  font-size: 0.7rem;
  font-weight: 700;
}

.operation-choice-group {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 0.55rem;
  margin-bottom: 0.8rem;
}

.operation-choice {
  border: 1px solid var(--panel-border);
  border-radius: 18px;
  padding: 0.72rem 0.78rem;
  background: var(--surface-soft);
  color: var(--text);
  text-align: left;
  cursor: pointer;
  transition: transform 0.16s ease, border-color 0.16s ease, background 0.16s ease, box-shadow 0.16s ease;
}

.operation-choice:hover {
  transform: translateY(-1px);
  border-color: var(--line-strong);
}

.operation-choice.active {
  border-color: transparent;
  background:
    radial-gradient(circle at 18% 12%, rgba(255, 255, 255, 0.22), transparent 32%),
    linear-gradient(135deg, #83dccd 0%, #36a893 100%);
  color: #ffffff;
  box-shadow: 0 16px 42px rgba(54, 168, 147, 0.24);
}

.operation-choice span,
.operation-choice small {
  display: block;
}

.operation-choice span {
  font-weight: 900;
}

.operation-choice small {
  margin-top: 0.14rem;
  color: var(--muted);
  font-size: 0.72rem;
}

.operation-choice.active small {
  color: rgba(255, 255, 255, 0.72);
}

.operation-field-hidden {
  display: none !important;
}

.quick-asset-card {
  display: grid;
  gap: 0.8rem;
  margin-bottom: 0.8rem;
  border: 1px solid rgba(122, 216, 199, 0.18);
  border-radius: 22px;
  padding: 0.95rem;
  background:
    radial-gradient(420px 190px at 100% 0%, rgba(122, 216, 199, 0.14), transparent 70%),
    var(--surface-soft);
}

.quick-asset-card[hidden] {
  display: none;
}

.quick-asset-card h3 {
  margin: 0.25rem 0 0.2rem;
}

.quick-asset-card p {
  margin: 0;
  color: var(--muted);
}

.quick-asset-grid {
  display: grid;
  grid-template-columns: 1fr 1.35fr 0.75fr 0.95fr auto;
  gap: 0.5rem;
  align-items: center;
}

.report-card-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 0.65rem;
  margin: 0.85rem 0;
}

.report-card {
  min-height: 112px;
  border: 1px solid var(--panel-border);
  border-radius: 20px;
  padding: 0.86rem;
  background:
    radial-gradient(240px 130px at 100% 0%, var(--chart-bg-top), transparent 72%),
    var(--surface-soft);
  color: var(--text);
  text-align: left;
  cursor: pointer;
  transition: transform 0.16s ease, border-color 0.16s ease, box-shadow 0.16s ease;
}

.report-card:hover {
  transform: translateY(-2px);
  border-color: var(--line-strong);
  box-shadow: var(--shadow);
}

.report-card.active {
  border-color: transparent;
  background:
    radial-gradient(circle at 18% 12%, rgba(255, 255, 255, 0.22), transparent 32%),
    linear-gradient(135deg, #83dccd 0%, #36a893 100%);
  color: #ffffff;
  box-shadow: 0 16px 42px rgba(54, 168, 147, 0.24);
}

.report-card strong,
.report-card span {
  display: block;
}

.report-card strong {
  font-size: 0.98rem;
}

.report-card span {
  margin-top: 0.28rem;
  color: var(--muted);
  font-size: 0.78rem;
  line-height: 1.35;
}

.report-card.active span {
  color: rgba(255, 255, 255, 0.72);
}

.record-sheet-overlay {
  position: fixed;
  inset: 0;
  z-index: 210;
  display: grid;
  align-items: end;
  padding: 1rem;
  background: rgba(3, 8, 12, 0.48);
  backdrop-filter: blur(8px);
}

.record-sheet-overlay[hidden] {
  display: none;
}

.record-sheet {
  width: min(720px, 100%);
  justify-self: center;
  position: relative;
  border: 1px solid rgba(122, 216, 199, 0.18);
  border-radius: 28px 28px 20px 20px;
  padding: 1.15rem;
  background:
    radial-gradient(520px 220px at 100% 0%, rgba(122, 216, 199, 0.13), transparent 72%),
    linear-gradient(180deg, rgba(18, 28, 39, 0.98), rgba(8, 13, 20, 0.98));
  color: #f4fbff;
  box-shadow: 0 34px 90px rgba(0, 0, 0, 0.44);
  animation: sheet-in 180ms ease;
}

@keyframes sheet-in {
  from {
    opacity: 0;
    transform: translateY(18px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.record-sheet h2 {
  margin: 0.2rem 2rem 0.8rem 0;
}

.record-sheet-close {
  position: absolute;
  top: 0.8rem;
  right: 0.8rem;
  width: 2.2rem;
  height: 2.2rem;
  border: 1px solid rgba(122, 216, 199, 0.18);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.06);
  color: #f4fbff;
  cursor: pointer;
}

.record-sheet-body {
  display: grid;
  gap: 0.45rem;
}

.record-detail-row {
  display: grid;
  grid-template-columns: minmax(120px, 0.34fr) minmax(0, 1fr);
  gap: 0.8rem;
  border-top: 1px solid rgba(122, 216, 199, 0.1);
  padding-top: 0.5rem;
}

.record-detail-row span {
  color: rgba(238, 247, 245, 0.58);
  font-size: 0.76rem;
  font-weight: 800;
}

.record-detail-row strong {
  min-width: 0;
  color: #ffffff;
  overflow-wrap: anywhere;
}

.confirm-dialog-overlay {
  position: fixed;
  inset: 0;
  z-index: 230;
  display: grid;
  place-items: center;
  padding: 1rem;
  background: rgba(3, 8, 12, 0.58);
  backdrop-filter: blur(10px);
}

.confirm-dialog-overlay[hidden] {
  display: none;
}

.confirm-dialog {
  width: min(440px, 100%);
  border: 1px solid rgba(255, 148, 142, 0.2);
  border-radius: 28px;
  padding: 1.15rem;
  background:
    radial-gradient(360px 180px at 100% 0%, rgba(255, 148, 142, 0.12), transparent 72%),
    linear-gradient(180deg, rgba(18, 28, 39, 0.98), rgba(8, 13, 20, 0.98));
  color: #f4fbff;
  box-shadow: 0 34px 90px rgba(0, 0, 0, 0.44);
  animation: menu-pop 160ms ease;
}

.confirm-dialog h2 {
  margin: 0.25rem 0 0.4rem;
}

.confirm-dialog .muted {
  color: rgba(238, 247, 245, 0.68);
}

.confirm-dialog-actions {
  display: flex;
  justify-content: flex-end;
  gap: 0.55rem;
  margin-top: 1rem;
  flex-wrap: wrap;
}

table {
  width: 100%;
  border-collapse: collapse;
  min-width: 480px;
}

th,
td {
  border-bottom: 1px solid rgba(214, 223, 211, 0.88);
  text-align: left;
  padding: 0.48rem 0.36rem;
  vertical-align: top;
  font-size: 0.86rem;
}

th {
  font-size: 0.72rem;
  letter-spacing: 0.03em;
  text-transform: uppercase;
  color: var(--muted);
}

td code {
  font-family: "IBM Plex Mono", "SFMono-Regular", monospace;
  font-size: 0.78rem;
}

.badge {
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  padding: 0.14rem 0.55rem;
  font-size: 0.72rem;
}

.badge.ok {
  background: rgba(14, 122, 100, 0.14);
  color: var(--brand-strong);
}

.badge.off {
  background: var(--badge-off-bg);
  color: var(--badge-off-text);
}

.badge.syncing {
  background: rgba(255, 127, 50, 0.16);
  color: var(--accent);
}

.hint,
.muted {
  color: var(--muted);
  font-size: 0.86rem;
}

.stack {
  display: grid;
  gap: 0.65rem;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  border-top: 1px solid var(--line);
  background: var(--glass);
  backdrop-filter: blur(9px);
  padding: 0.6rem 1.3rem;
}

.footer p {
  margin: 0;
  font-size: 0.82rem;
  color: var(--muted);
}

.footer .hint {
  max-width: 44rem;
  text-align: center;
}

.cloud-auth-overlay {
  position: fixed;
  inset: 0;
  z-index: 120;
  display: grid;
  place-items: center;
  padding: 1.2rem;
  background:
    radial-gradient(circle at 20% 16%, rgba(14, 122, 100, 0.38), transparent 34%),
    radial-gradient(circle at 82% 10%, rgba(255, 127, 50, 0.22), transparent 30%),
    linear-gradient(145deg, rgba(4, 9, 13, 0.94), rgba(10, 18, 25, 0.9));
  backdrop-filter: blur(12px);
}

.cloud-auth-overlay[hidden] {
  display: none;
}

.cloud-auth-card {
  width: min(520px, 100%);
  border: 1px solid rgba(122, 216, 199, 0.16);
  border-radius: 30px;
  padding: 1.45rem;
  background:
    linear-gradient(180deg, rgba(18, 28, 37, 0.98), rgba(9, 15, 22, 0.98)),
    var(--panel-strong);
  color: #eef7f5;
  box-shadow: 0 34px 90px rgba(0, 0, 0, 0.42);
}

.cloud-auth-card h2 {
  margin: 0.1rem 0 0.45rem;
  font-size: clamp(1.45rem, 4vw, 2rem);
}

.cloud-auth-card .muted,
.cloud-auth-card .hint,
.cloud-auth-card .eyebrow {
  color: rgba(238, 247, 245, 0.72);
}

.cloud-auth-card .control > span {
  color: rgba(238, 247, 245, 0.74);
}

.cloud-auth-card input {
  border-color: rgba(122, 216, 199, 0.16);
  background: rgba(4, 10, 16, 0.72);
  color: #f5fffc;
}

.cloud-auth-card input:focus {
  border-color: rgba(122, 216, 199, 0.55);
  box-shadow: 0 0 0 3px rgba(122, 216, 199, 0.12);
  outline: none;
}

.cloud-auth-form {
  display: grid;
  gap: 0.85rem;
  margin-top: 1rem;
}

.cloud-auth-form .btn {
  justify-content: center;
}

.cloud-dev-settings {
  border: 1px dashed rgba(122, 216, 199, 0.2);
  border-radius: 18px;
  padding: 0.75rem;
  background: rgba(255, 255, 255, 0.04);
}

.cloud-dev-settings summary {
  cursor: pointer;
  color: rgba(238, 247, 245, 0.7);
  font-weight: 700;
}

.cloud-dev-settings[open] {
  display: grid;
  gap: 0.75rem;
}

.cloud-dev-settings[open] summary {
  margin-bottom: 0.4rem;
}

body.cloud-syncing #cloudSyncStatus {
  background: rgba(255, 127, 50, 0.16);
  color: var(--accent);
}

body[data-font-scale="compact"] .panel,
body[data-font-scale="compact"] .stat-card,
body[data-font-scale="compact"] .tab {
  border-radius: 16px;
}

body[data-font-scale="compact"] th,
body[data-font-scale="compact"] td,
body[data-font-scale="compact"] input,
body[data-font-scale="compact"] select,
body[data-font-scale="compact"] textarea,
body[data-font-scale="compact"] .btn {
  font-size: 0.94em;
}

body[data-font-scale="large"] .panel,
body[data-font-scale="large"] .stat-card {
  border-radius: 22px;
}

body[data-font-scale="large"] th,
body[data-font-scale="large"] td,
body[data-font-scale="large"] input,
body[data-font-scale="large"] select,
body[data-font-scale="large"] textarea,
body[data-font-scale="large"] .btn {
  font-size: 1.04em;
}

.appearance-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.75rem;
  margin-bottom: 1rem;
}

.appearance-grid.compact {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.appearance-card {
  display: grid;
  gap: 0.55rem;
  width: 100%;
  min-height: 128px;
  padding: 0.9rem;
  border: 1px solid var(--line);
  border-radius: 18px;
  background: var(--surface-soft);
  color: var(--text);
  text-align: left;
  cursor: pointer;
  transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease, background-color 160ms ease;
}

.appearance-card.compact {
  min-height: 104px;
}

.appearance-card:hover {
  transform: translateY(-2px);
  border-color: var(--line-strong);
}

.appearance-card.active {
  border-color: var(--brand);
  box-shadow: 0 0 0 4px var(--chart-selection-fill);
  background: var(--panel-strong);
}

.appearance-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 0.6rem;
}

.appearance-card-title {
  display: block;
  font-weight: 700;
}

.appearance-card-copy {
  display: block;
  font-size: 0.8rem;
  color: var(--muted);
  line-height: 1.45;
}

.appearance-card-check {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 1.4rem;
  height: 1.4rem;
  border-radius: 999px;
  background: color-mix(in srgb, var(--brand) 14%, transparent);
  color: var(--brand-strong);
  font-size: 0.78rem;
}

.appearance-swatches {
  display: flex;
  gap: 0.42rem;
}

.appearance-swatch {
  width: 1.15rem;
  height: 1.15rem;
  border-radius: 999px;
  border: 1px solid rgba(0, 0, 0, 0.08);
  box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.22);
}

.appearance-icons {
  display: flex;
  align-items: center;
  gap: 0.42rem;
  color: var(--brand-strong);
  font-size: 1.02rem;
}

.appearance-preview-shell {
  display: grid;
}

.appearance-preview {
  display: grid;
  gap: 0.8rem;
  padding: 1rem;
  border-radius: 22px;
  border: 1px solid var(--panel-border);
  background:
    radial-gradient(120% 120% at 100% 0%, var(--chart-bg-top), transparent 54%),
    linear-gradient(180deg, var(--panel-strong) 0%, var(--panel) 100%);
}

.appearance-preview-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.appearance-preview-brand strong {
  display: block;
  font-size: 1rem;
}

.appearance-preview-brand span {
  color: var(--muted);
  font-size: 0.8rem;
}

.appearance-preview-controls {
  display: flex;
  gap: 0.55rem;
  flex-wrap: wrap;
}

.appearance-pill {
  display: inline-flex;
  align-items: center;
  gap: 0.44rem;
  min-height: 38px;
  padding: 0.5rem 0.85rem;
  border-radius: 999px;
  border: 1px solid var(--line);
  background: var(--surface-strong);
  color: var(--text);
}

.appearance-pill.active {
  border-color: transparent;
  background: linear-gradient(120deg, var(--brand-strong), var(--brand));
  color: #ffffff;
}

.appearance-preview-body {
  display: grid;
  grid-template-columns: 1.25fr 0.75fr;
  gap: 0.75rem;
}

.appearance-preview-card {
  padding: 0.9rem;
  border-radius: 18px;
  border: 1px solid var(--line);
  background: var(--surface-soft);
}

.appearance-preview-card h4 {
  margin: 0 0 0.75rem;
  font-size: 0.98rem;
}

.appearance-preview-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.55rem;
}

.appearance-mini-stat {
  padding: 0.72rem;
  border-radius: 14px;
  border: 1px solid var(--line);
  background: var(--surface-strong);
}

.appearance-mini-stat span {
  display: block;
  color: var(--muted);
  font-size: 0.75rem;
}

.appearance-mini-stat strong {
  display: block;
  margin-top: 0.18rem;
  font-size: 1rem;
}

.appearance-preview-actions {
  display: flex;
  gap: 0.55rem;
  flex-wrap: wrap;
  margin-top: 0.8rem;
}

.appearance-mini-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.42rem;
  min-height: 38px;
  padding: 0.5rem 0.82rem;
  border-radius: 12px;
  border: 1px solid transparent;
  background: linear-gradient(120deg, var(--brand), var(--brand-strong));
  color: #ffffff;
  font-weight: 600;
}

.appearance-mini-btn.secondary {
  background: var(--surface-strong);
  border-color: var(--line-strong);
  color: var(--text);
}

.appearance-preview-list {
  display: grid;
  gap: 0.6rem;
}

.appearance-mini-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  padding-bottom: 0.55rem;
  border-bottom: 1px solid rgba(214, 223, 211, 0.72);
}

.appearance-mini-row:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.appearance-mini-row span {
  color: var(--muted);
  font-size: 0.78rem;
}

.appearance-mini-row strong {
  font-size: 0.9rem;
}

hr {
  border: 0;
  border-top: 1px solid var(--line);
  margin: 0.95rem 0;
}

@media (max-width: 1120px) {
  .grid-two {
    grid-template-columns: 1fr;
  }

  .stats-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .dashboard-premium-head {
    grid-template-columns: 1fr;
  }

  .dashboard-quick-actions {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    min-width: 0;
  }

  .topbar {
    position: static;
    flex-direction: column;
  }

  .footer {
    position: static;
    margin-top: 1rem;
  }
}

@media (max-width: 760px) {
  .container {
    padding: 0.75rem;
  }

  .form-grid {
    grid-template-columns: 1fr;
  }

  .topbar-actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: stretch;
    width: 100%;
  }

  .topbar-actions .control,
  .topbar-actions .btn,
  .topbar-actions .file-btn,
  .account-menu-wrap,
  .account-chip {
    width: 100%;
  }

  .account-menu {
    position: fixed;
    top: auto;
    right: 0.75rem;
    bottom: 0.75rem;
    left: 0.75rem;
    width: auto;
  }

  .tabs {
    gap: 0.35rem;
    padding: 0.55rem 0.6rem;
  }

  .tab {
    min-height: 44px;
    padding: 0.55rem 0.82rem;
    font-size: 0.81rem;
  }

  .panel {
    border-radius: 18px;
    padding: 0.8rem;
  }

  .appearance-grid,
  .appearance-grid.compact,
  .appearance-preview-body {
    grid-template-columns: 1fr;
  }

  .panel-head {
    gap: 0.7rem;
  }

  .dashboard-controls {
    width: 100%;
  }

  .actions-inline {
    gap: 0.5rem;
  }

  .actions-inline .control.inline {
    flex-basis: 100%;
  }

  .dashboard-controls .control.inline {
    flex: 1 1 100%;
  }

  .btn {
    min-height: 46px;
    padding: 0.7rem 0.95rem;
  }

  input,
  select,
  textarea,
  button {
    font-size: 16px;
  }

  .chart-wrap {
    padding: 0.45rem;
  }

  .chart-toolbar,
  .chart-toolbar-actions {
    align-items: stretch;
  }

  .chart-toolbar-actions {
    width: 100%;
    justify-content: space-between;
  }

  th,
  td {
    padding: 0.38rem 0.28rem;
    font-size: 0.79rem;
  }

  th {
    font-size: 0.65rem;
  }

  table {
    min-width: 400px;
  }

  .stats-grid {
    grid-template-columns: 1fr;
  }

  .dashboard-mini-stats {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .empty-hero {
    align-items: stretch;
    flex-direction: column;
  }

  .operation-choice-group {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .quick-asset-grid,
  .report-card-grid,
  .onboarding-card,
  .onboarding-steps {
    grid-template-columns: 1fr;
  }

  .record-card {
    grid-template-columns: 1fr;
  }

  .record-value {
    text-align: left;
  }

  .record-detail-row {
    grid-template-columns: 1fr;
    gap: 0.18rem;
  }
}

@media (max-width: 520px) {
  .topbar-actions {
    grid-template-columns: 1fr;
  }

  .tabs {
    padding-inline: 0.45rem;
  }

  .tab {
    font-size: 0.78rem;
    padding-inline: 0.74rem;
  }

  .panel h2 {
    font-size: 1.02rem;
  }

  .chart-range-group {
    width: 100%;
  }

  .chart-mode-group {
    width: 100%;
  }

  .operation-choice-group {
    grid-template-columns: 1fr;
  }

  .dashboard-quick-actions,
  .dashboard-mini-stats {
    grid-template-columns: 1fr;
  }

  .stat-card-hero {
    min-height: 160px;
  }

  .chart-range-btn {
    flex: 1 1 auto;
  }

  .chart-mode-btn {
    flex: 1 1 auto;
  }

  .appearance-preview-stats {
    grid-template-columns: 1fr;
  }

  th,
  td {
    padding: 0.32rem 0.22rem;
    font-size: 0.75rem;
  }

  table {
    min-width: 360px;
  }
}
